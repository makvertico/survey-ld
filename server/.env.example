# PostgreSQL via PgBouncer (port 6432)
DATABASE_URL=postgresql://ld_user:your_strong_password@localhost:6432/ld_survey

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex_secret
JWT_EXPIRES_IN=12h

PORT=3001
NODE_ENV=production

# CORS — set to your Vercel frontend URL in production
CORS_ORIGIN=https://your-app.vercel.app
